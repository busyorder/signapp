<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_purple_gradient"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 🔥 Title -->
        <TextView
            android:text="Learn Sign Language"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#EEFFFFFF"
        android:layout_marginBottom="20dp"
        android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:text="Basic Alphabet ABC"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="9dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Buttons -->
        <Button style="@style/ModernButton"
            android:layout_width="340dp"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:id="@+id/btnAlphabet"
            android:text="ASL Alphabet ABC"/>
    </LinearLayout>
    </androidx.cardview.widget.CardView>

        <!-- 🌟 BASIC GREETINGS CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#EEFFFFFF"
            android:layout_marginBottom="20dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:text="Basic Greetings"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginStart="9dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Buttons -->
                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnHello"
                    android:text="Hello"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnYes"
                    android:text="Yes"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnNo"
                    android:text="No"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnThankYou"
                    android:text="Thank You"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnWelcome"
                    android:text="Welcome"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnPlease"
                    android:text="Please"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnSorry"
                    android:text="Sorry"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 🌅 TIME GREETINGS CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#EEFFFFFF"
            android:layout_marginBottom="20dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:text="Time Greetings"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginStart="9dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnGoodMorning"
                    android:text="Good Morning"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnGoodAfternoon"
                    android:text="Good Afternoon"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnGoodNight"
                    android:text="Good Night"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ❓ HELP & QUESTIONS CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#EEFFFFFF"
            android:layout_marginBottom="30dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:text="Help &amp; Questions"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginStart="9dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnHelp"
                    android:text="Help"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnWhat"
                    android:text="What"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnWhere"
                    android:text="Where"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnHowAreYou"
                    android:text="How Are You"/>

                <Button style="@style/ModernButton"
                    android:layout_width="340dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:id="@+id/btnIAmSorry"
                    android:text="I Am Sorry"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
